# Postgres (homelab container, ports bound to localhost + Tailscale)
# Prod (homelab): use 127.0.0.1:5433
# Dev (Mac over Tailscale): use homelab:5433
DATABASE_URL="postgresql://thadar:CHANGEME@127.0.0.1:5433/thadar?schema=public"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET="CHANGEME"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth (wired manually by the owner — leave blank to disable)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend — transactional email. If RESEND_API_KEY is unset, all email sends
# become logged no-ops so local dev works without a provider.
RESEND_API_KEY=""
# From addresses must use a verified sending domain (DKIM/SPF/DMARC) before
# going public. noreply = system mail, hello = anything a human may reply to.
EMAIL_FROM_NOREPLY="Thadar <noreply@thadar.com>"
EMAIL_FROM_HELLO="Thadar <hello@thadar.com>"
